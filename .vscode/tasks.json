{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "compile-extension",
			"type": "npm",
			"script": "compile",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": "$tsc"
		},
		{
			"label": "npm: watch",
			"type": "npm",
			"script": "watch",
			"isBackground": true,
			"problemMatcher": {
				"owner": "webpack",
				"pattern": {
					"regexp": "^$"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "\\[webpack-cli\\] Compiler starting",
					"endsPattern": "(Failed to compile|webpack \\d+\\.\\d+\\.\\d+ compiled)"
				}
			},
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": "build"
		},
		{
			"type": "npm",
			"script": "watch-tests",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": "build"
		},
		{
			"label": "tasks: watch-tests",
			"dependsOn": [
				"npm: watch",
				"npm: watch-tests"
			],
			"problemMatcher": [
				{
					"owner": "webpack",
					"pattern": {
						"regexp": "^$"
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": "\\[webpack-cli\\] Compiler starting",
						"endsPattern": "(Failed to compile|webpack \\d+\\.\\d+\\.\\d+ compiled)"
					}
				},
				"$tsc-watch"
			]
		}
	]
}
